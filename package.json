  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "author": "CumpliSent Team",
  "description": "Sistema de Control de Cumplimiento de Sentencias",
  "build": {
    "appId": "mx.intranet.cumplisent",
    "productName": "CumpliSent",
    "artifactName": "CumpliSentInstallerv9.4.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "Images/**/*",
      "package.json"
    ],
    "win": {
      "icon": "Images/Cumplisent.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "CumpliSent",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
